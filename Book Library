from os import name
books=[]
issued_books=[]

def add_books():
  name=input("enter the book name:")
  books.append(name)
  print(name,'is added')

def show_books():
   if len(books) == 0:
    print("no books available")
   else:
    print('books available')
    for book in books:
      print(book)

def issue_books():
  if len(books)==0:
    print("no books available")
    return
  name=input("enter the book name you want to issue:")
  if name in books:
    issued_books.append(name)
    books.remove(name)
    print(name,"is issued")
  else:
    print(name,"book is not available")

def return_books():
  name=input("enter the book name you want to return:")
  if name in issued_books:
    books.append(name)
    issued_books.remove(name)
    print(name,"is returned")
  else:
    print(name,"book is not issued from library")


def library():
  while True:
    print("1.add books")
    print("2.show books")
    print("3.issue books")
    print("4.return books")
    print("5.exit")

    choice=int(input("\nenter your choice:"))
    if choice==1:
      add_books()
    if choice==2:
      show_books()
    if choice==3:
      issue_books()
    if choice==4:
      return_books()
    if choice==5:
      break
    else:
      print("\nThankyou")

library()
