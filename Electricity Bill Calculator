readings = []

def add_reading():
  date = input("enter the date: ")
  unit = int(input("enter the reading: "))
  readings.append({"date": date, "unit": unit})

def view_consumption():
  if len(readings) < 1:
    print("not enough information")
    return

  print("/ndaily conmsumption: ")
  for i in range(1, len(readings)):
    diff = readings[i]["unit"] - readings[i-1]["unit"]
    print(readings[i]["date"], ":" , diff, "units")


def calculate_bills():

    if len(readings) < 2:
        print("Not enough data to calculate bill")
        return

    rate = float(input("Enter rate per unit: "))

    total_unit = readings[-1]["unit"] - readings[0]["unit"]
    bill = total_unit * rate

    print("Total units consumed:", total_unit)
    print("Rate per unit:", rate)
    print("Total bill:", bill)

def menu():
  while True:
    print("1. add reading")
    print("2. view consumption")
    print("3. calculate bills")
    print("4. exit")

    choice = input("enter your choice: ")

    if choice == "1":
      add_reading()
    elif choice == "2":
      view_consumption()
    elif choice == "3":
      calculate_bills()
    elif choice == "4":
      break
    else:
      print("Invalid choice")
      print("return to menu")

menu()
